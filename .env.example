# Discord bot credentials — copy to .env (chmod 600) and fill in.
# Never commit the real .env (already gitignored).

# Bot token from Discord Developer Portal → Applications → <app> → Bot
BOT_TOKEN=

# Application (client) ID from Discord Developer Portal → Applications → <app>
CLIENT_ID=

# Server ID where slash commands register (right-click guild → Copy Server ID)
GUILD_ID=

# Optional: DonutSMP API
DONUTSMP_API_KEY=
DONUTSMP_BASE_URL=https://api.donutsmp.net
DONUTSMP_STATS_PATH=/v1/stats/{user}
DONUTSMP_BALANCE_JSON_PATH=result.money
